\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces 第 32 个模拟实现的过密度切片视觉比较。左：N 体模拟参考结果，显示非线性演化后的团块、丝状结构和空洞；中：ZA 基准结果，小尺度结构更平滑、团块更弥散；右：新流程结果，在保留大尺度结构的同时恢复出更紧凑的小尺度团块和更丰富的细节。}}{12}{figure.caption.17}\protected@file@percent }
\newlabel{fig:density-slice}{{3.1}{12}{第 32 个模拟实现的过密度切片视觉比较。左：N 体模拟参考结果，显示非线性演化后的团块、丝状结构和空洞；中：ZA 基准结果，小尺度结构更平滑、团块更弥散；右：新流程结果，在保留大尺度结构的同时恢复出更紧凑的小尺度团块和更丰富的细节。}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces 过密度残差 $\mitdelta _{\mathrm {method}}-\mitdelta _{\mathrm {ref}}$ 的概率分布函数，其中参考场为 N 体模拟。曲线统计第 32--47 个模拟实现，阴影表示不同实现的 $1\mitsigma $ 散布；ZA、2LPT 和 ALPT 的残差分布尾部更宽，新流程的残差更集中于 0 附近，说明单点统计恢复更接近 N 体结果。}}{13}{figure.caption.18}\protected@file@percent }
\newlabel{fig:density-pdf}{{3.2}{13}{过密度残差 $\delta _{\mathrm {method}}-\delta _{\mathrm {ref}}$ 的概率分布函数，其中参考场为 N 体模拟。曲线统计第 32--47 个模拟实现，阴影表示不同实现的 $1\sigma $ 散布；ZA、2LPT 和 ALPT 的残差分布尾部更宽，新流程的残差更集中于 0 附近，说明单点统计恢复更接近 N 体结果。}{figure.caption.18}{}}
